# HalalCheckBot — Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MiniMax API Key (for AI ingredient classification)
# Get yours at: https://platform.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here

# Flask secret key (generate a random string)
SECRET_KEY=change-this-to-a-random-secret-key

# Admin password for web dashboard
ADMIN_PASSWORD=change-this-admin-password

# Flask port (default: 5000)
PORT=5000

# Flask debug mode (true/false)
FLASK_DEBUG=false
